# ─────────────────────────────────────────────────────────────────────────────
# TidalBrix Dummy — .env
#
# Mirrors the real .env.example shape.
# All values here are SAFE DUMMIES — no real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── App mode ──────────────────────────────────────────────────────────────
APP_MODE=dummy

# ── Database (same keys as real app) ─────────────────────────────────────
POSTGRES_USER=tidalbrix
POSTGRES_PASSWORD=tidalbrix
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=tidalbrix

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000

# ── Auth (dummy secret — not used for real verification) ──────────────────
JWT_SECRET_KEY=dummy-secret-key-not-real-replace-in-production

# ── Copernicus / CMEMS (NOT NEEDED in dummy mode) ─────────────────────────
# Real app needs:
#   COPERNICUS_USERNAME=your@email.com
#   COPERNICUS_PASSWORD=yourpassword
# Dummy mode skips all external data fetching.

# ── SMTP (NOT NEEDED in dummy mode) ──────────────────────────────────────
# Real app sends emails for onboarding.
# Dummy mode skips email sending.
